<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - TaskManager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
          integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
    @Styles.Render("~/Content/css")
    <style>
        body { padding-top: 70px; }
        .navbar-brand { font-weight: 600; }
        .badge { font-weight: 500; }
        .table thead th { font-size: .85rem; text-transform: uppercase; letter-spacing: .04em; color: #555; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Index", "Home")">TaskManager</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div id="nav" class="collapse navbar-collapse">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Tasks")">Tasks</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Dashboard")">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Diagnostics")">Diagnostics</a></li>
                    <li class="nav-item"><a class="nav-link" href="/WebForms/SqlQueries.aspx">SQL Queries</a></li>
                    @if (Request.IsAuthenticated && (HttpContext.Current.Items["UserRole"] as string) == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link" href="@Url.Action("Index", "Users")">Users</a></li>
                    }
                </ul>
                @Html.Partial("_LoginPartial")
            </div>
        </div>
    </nav>
    <div class="container">
        @if (TempData["UploadError"] != null)
        {
            <div class="alert alert-danger">@TempData["UploadError"]</div>
        }
        @RenderBody()
        <hr />
        <footer class="text-muted small">
            &copy; @DateTime.UtcNow.Year TaskManager - APM testing sample - request id <code>@(System.Web.HttpContext.Current.Items["__req_correlation"] as string ?? "n/a")</code>
        </footer>
    </div>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <script src="@Url.Content("~/Scripts/site.js")"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
