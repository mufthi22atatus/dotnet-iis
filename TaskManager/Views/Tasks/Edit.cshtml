@model TaskManager.ViewModels.TaskUpdateInput
@{
    ViewBag.Title = "Edit task";
    var taskId = (int)ViewBag.TaskId;
}
<h2>Edit task</h2>
@using (Html.BeginForm("Edit", "Tasks", new { id = taskId }, FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="row g-3">
        <div class="col-md-8">
            @Html.LabelFor(m => m.Title, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Title, new { @class = "form-control" })
            @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger small" })
        </div>
        <div class="col-md-4">
            @Html.LabelFor(m => m.Tag, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Tag, new { @class = "form-control" })
        </div>
        <div class="col-12">
            @Html.LabelFor(m => m.Description, new { @class = "form-label" })
            @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = 4 })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.Status, new { @class = "form-label" })
            @Html.EnumDropDownListFor(m => m.Status, new { @class = "form-select" })
        </div>
        <div class="col-md-3">
            @Html.LabelFor(m => m.Priority, new { @class = "form-label" })
            @Html.EnumDropDownListFor(m => m.Priority, new { @class = "form-select" })
        </div>
        <div class="col-md-2">
            @Html.LabelFor(m => m.DueDate, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.DueDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
        </div>
        <div class="col-md-2">
            @Html.LabelFor(m => m.EstimatedHours, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.EstimatedHours, new { @class = "form-control", type = "number", min = 0 })
        </div>
        <div class="col-md-2">
            @Html.LabelFor(m => m.LoggedHours, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.LoggedHours, new { @class = "form-control", type = "number", min = 0 })
        </div>
    </div>
    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a class="btn btn-link" href="@Url.Action("Details", new { id = taskId })">Cancel</a>
    </div>
}
