<?xml version="1.0" encoding="utf-8"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <!-- Debug transforms (no-op by default; the base Web.config is already dev-friendly) -->
  <appSettings>
    <add key="Environment" value="Debug" xdt:Transform="InsertIfMissing" />
  </appSettings>
</configuration>
